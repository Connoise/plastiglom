# Plastiglom environment configuration
# Copy to .env and fill in. Never commit .env.

# Path to the private Obsidian vault. Must already exist.
PLASTIGLOM_VAULT_PATH=/home/vaults/Plastiglom

# Local timezone used for scheduling and lock_at computation.
PLASTIGLOM_TIMEZONE=America/Los_Angeles

# Main exercise firing times (local time, 24h).
PLASTIGLOM_MORNING_FIRE=07:30
PLASTIGLOM_EVENING_FIRE=21:00

# Telegram notification channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web app base URL used in deep links.
PLASTIGLOM_WEB_BASE_URL=http://plastiglom.local

# Anthropic API.
ANTHROPIC_API_KEY=

# Model IDs. Routing is enforced in packages/llm regardless of these.
PLASTIGLOM_MODEL_SONNET=claude-sonnet-4-6
PLASTIGLOM_MODEL_OPUS=claude-opus-4-7

# QMD CLI invocation. Leave default unless QMD lives elsewhere.
PLASTIGLOM_QMD_BIN=qmd
